---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="detail-page">
		<div class="back-button">
			<a href="/">← 返回首页</a>
		</div>

		<!-- 项目经历内容 -->
		<section class="content-section">
			<h2 class="section-title">
				<span class="icon">🎨</span>
				项目经历
			</h2>

			<!-- 项目示例 -->
			<div class="timeline-item">
				<div class="timeline-dot"></div>
				<div class="timeline-content">
					<div class="time-period">2024.XX - 2024.XX</div>
					<h3>项目名称</h3>
					<p class="position">项目角色 | 项目类型</p>
					<div class="details">
						<h4>项目描述</h4>
						<p>在这里填写项目的详细描述...</p>

						<h4>主要职责</h4>
						<p>在这里填写你的主要职责和工作内容...</p>

						<h4>项目成果</h4>
						<p>在这里填写项目取得的成果和数据...</p>
					</div>
				</div>
			</div>

			<!-- 可以复制上面的 timeline-item 添加更多项目 -->
		</section>
	</main>
</Layout>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap');

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		background: url('/background.jpg') no-repeat center center fixed;
		background-size: cover;
		font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
		color: #333;
		position: relative;
	}

	body::before {
		content: '';
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(255, 255, 255, 0.7);
		z-index: -1;
	}

	.detail-page {
		max-width: 800px;
		margin: 0 auto;
		padding: 1.5rem;
		min-height: 100vh;
	}

	.back-button {
		margin-bottom: 2rem;
	}

	.back-button a {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: #4a90e2;
		text-decoration: none;
		font-weight: 500;
		transition: all 0.3s ease;
		padding: 0.5rem 1rem;
		border-radius: 8px;
	}

	.back-button a:hover {
		background: rgba(74, 144, 226, 0.1);
		transform: translateX(-5px);
	}

	.detail-header {
		text-align: center;
		margin-bottom: 2rem;
	}

	.detail-header h1 {
		font-size: 1.8rem;
		font-weight: 600;
		color: #1a1a1a;
	}

	.content-section {
		margin-bottom: 3rem;
	}

	.section-title {
		font-size: 1.3rem;
		font-weight: 600;
		color: #1a1a1a;
		margin-bottom: 1.5rem;
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.section-title .icon {
		font-size: 1.2rem;
	}

	.timeline-item {
		position: relative;
		padding-left: 2rem;
		margin-bottom: 1.8rem;
	}

	.timeline-item:last-child {
		margin-bottom: 0;
	}

	.timeline-dot {
		position: absolute;
		left: 0;
		top: 0.3rem;
		width: 14px;
		height: 14px;
		background: #4a90e2;
		border-radius: 50%;
		box-shadow: 0 0 0 4px rgba(74, 144, 226, 0.2);
	}

	.timeline-item::before {
		content: '';
		position: absolute;
		left: 6px;
		top: 1.5rem;
		bottom: -2rem;
		width: 2px;
		background: linear-gradient(to bottom, #4a90e2, rgba(74, 144, 226, 0.2));
	}

	.timeline-item:last-child::before {
		display: none;
	}

	.timeline-content {
		background: white;
		padding: 1.2rem;
		border-radius: 10px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
		transition: all 0.3s ease;
	}

	.timeline-content:hover {
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
		transform: translateX(5px);
	}

	.time-period {
		color: #4a90e2;
		font-weight: 600;
		font-size: 0.85rem;
		margin-bottom: 0.6rem;
	}

	.timeline-content h3 {
		font-size: 1.1rem;
		font-weight: 600;
		color: #1a1a1a;
		margin-bottom: 0.4rem;
	}

	.position {
		color: #666;
		font-size: 0.9rem;
		margin-bottom: 1rem;
	}

	.details {
		line-height: 1.8;
	}

	.details h4 {
		font-size: 0.95rem;
		font-weight: 600;
		color: #2c3e50;
		margin: 1rem 0 0.5rem;
	}

	.details h4:first-child {
		margin-top: 0;
	}

	.details p {
		color: #555;
		font-size: 0.9rem;
		line-height: 1.6;
		margin-bottom: 0.6rem;
	}

	.details ul {
		margin-left: 1.5rem;
		color: #555;
	}

	.details li {
		margin-bottom: 0.5rem;
	}

	/* 响应式设计 */
	@media (max-width: 768px) {
		.detail-page {
			padding: 1rem;
		}

		.detail-header h1 {
			font-size: 2rem;
		}

		.section-title {
			font-size: 1.5rem;
		}

		.timeline-item {
			padding-left: 2rem;
		}

		.timeline-content {
			padding: 1.2rem;
		}

		.timeline-content h3 {
			font-size: 1.2rem;
		}
	}
</style>
